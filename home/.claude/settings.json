{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(composer validate*)",
      "Bash(vendor/bin/phpunit*)",
      "Bash(vendor/bin/phpstan*)",
      "Bash(vendor/bin/php-cs-fixer fix --dry-run*)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run typecheck*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run typecheck*)",
      "Bash(yarn lint*)",
      "Bash(yarn test*)",
      "Bash(yarn typecheck*)"
    ],
    "deny": [
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/.envrc)",
      "Read(//**/.npmrc)",
      "Read(//**/.pypirc)",
      "Read(//**/auth.json)",
      "Read(//**/secrets/**)",
      "Read(//**/config/secrets/**)",
      "Read(//**/config/jwt/**)",
      "Read(//**/*.pem)",
      "Read(//**/*.key)",
      "Read(//**/*.crt)",
      "Read(//**/*.p12)",
      "Read(//**/*.pfx)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.config/glab-cli/**)",
      "Read(~/.config/composer/auth.json)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.config/git/credentials)",
      "Read(~/.git-credentials)",
      "Read(~/.netrc)",
      "Edit(//**/.env)",
      "Edit(//**/.env.*)",
      "Edit(//**/.envrc)",
      "Edit(//**/.npmrc)",
      "Edit(//**/.pypirc)",
      "Edit(//**/auth.json)",
      "Edit(//**/secrets/**)",
      "Edit(//**/config/secrets/**)",
      "Edit(//**/config/jwt/**)",
      "Edit(//**/*.pem)",
      "Edit(//**/*.key)",
      "Edit(//**/*.crt)",
      "Edit(//**/*.p12)",
      "Edit(//**/*.pfx)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.azure/**)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.config/glab-cli/**)",
      "Edit(~/.config/composer/auth.json)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.kube/**)",
      "Edit(~/.config/git/credentials)",
      "Edit(~/.git-credentials)",
      "Edit(~/.netrc)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(sudo*)",
      "Bash(chmod 777*)",
      "Bash(chown*)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker compose down -v*)",
      "Bash(gh auth token*)",
      "Bash(gh auth status --show-token*)",
      "Bash(glab auth token*)",
      "Bash(*.env*)",
      "Bash(*.pem*)",
      "Bash(*.key*)",
      "Bash(*.crt*)",
      "Bash(*.p12*)",
      "Bash(*.pfx*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git restore*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(git pull*)",
      "Bash(docker compose*)",
      "Bash(docker run*)",
      "Bash(docker exec*)",
      "Bash(composer install*)",
      "Bash(composer update*)",
      "Bash(composer require*)",
      "Bash(composer remove*)",
      "Bash(npm install*)",
      "Bash(npm update*)",
      "Bash(npm add*)",
      "Bash(npm remove*)",
      "Bash(pnpm install*)",
      "Bash(pnpm update*)",
      "Bash(pnpm add*)",
      "Bash(pnpm remove*)",
      "Bash(yarn install*)",
      "Bash(yarn upgrade*)",
      "Bash(yarn add*)",
      "Bash(yarn remove*)",
      "Bash(bin/console doctrine*)",
      "Bash(php bin/console doctrine*)",
      "Bash(./bin/console doctrine*)",
      "Bash(symfony console doctrine*)"
    ],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.config/gh",
        "~/.config/glab-cli",
        "~/.config/composer/auth.json",
        "~/.docker/config.json",
        "~/.kube",
        "~/.config/git/credentials",
        "~/.git-credentials",
        "~/.netrc",
        "/etc",
        "/usr",
        "/bin",
        "/sbin",
        "/boot"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.config/gh",
        "~/.config/glab-cli",
        "~/.config/composer/auth.json",
        "~/.docker/config.json",
        "~/.kube",
        "~/.config/git/credentials",
        "~/.git-credentials",
        "~/.netrc"
      ]
    }
  },
  "theme": "dark"
}
